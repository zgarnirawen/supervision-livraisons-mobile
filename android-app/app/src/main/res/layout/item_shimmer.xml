<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <View android:layout_width="5dp" android:layout_height="match_parent"
            android:background="#E0E0E0" android:layout_marginEnd="14dp"/>

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View android:layout_width="160dp" android:layout_height="14dp"
                android:background="#E0E0E0" android:layout_marginBottom="8dp"/>
            <View android:layout_width="220dp" android:layout_height="14dp"
                android:background="#E8E8E8" android:layout_marginBottom="6dp"/>
            <View android:layout_width="140dp" android:layout_height="12dp"
                android:background="#EEEEEE" android:layout_marginBottom="6dp"/>
            <View android:layout_width="100dp" android:layout_height="12dp"
                android:background="#F0F0F0"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
